{
	"name": "crosis4furrets",
	"version": "0.0.1-beta.7",
	"description": "An abstraction of Crosis, the Replit Protocol Client.",
	"sideEffects": false,
	"type": "module",
	"main": "./dist/crosis4furrets.cjs",
	"module": "./dist/crosis4furrets.mjs",
	"exports": {
		".": {
			"import": "./dist/crosis4furrets.mjs",
			"require": "./dist/crosis4furrets.cjs",
			"default": "./dist/crosis4furrets.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"test": "node tests/common.test.cjs && node tests/esm.test.mjs",
		"test:cjs": "node tests/common.test.cjs",
		"test:mjs": "node tests/esm.test.mjs",
		"lint": "eslint src --config ./eslint.config.json --ext .js",
		"lint:fix": "eslint src --config ./eslint.config.json --ext .js --fix",
		"format": "prettier --check . --config ./prettier.config.json",
		"format:fix": "prettier --write . --config ./prettier.config.json",
		"build": "rimraf ./dist/** && rollup --config",
		"build:cjs": "rimraf ./dist/crosis4furrets.cjs && rollup src/index.js --file dist/crosis4furrets.cjs --format cjs",
		"build:mjs": "rimraf ./dist/crosis4furrets.mjs && rollup src/index.js --file dist/crosis4furrets.mjs --format esm"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/RayhanADev/crosis4furrets.git"
	},
	"keywords": [
		"fetch",
		"https",
		"async",
		"request"
	],
	"author": "Ray Arayilakath <rayhanadev@pm.me> (https://rayhanadev.vercel.app)",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/RayhanADev/crosis4furrets/issues"
	},
	"homepage": "https://github.com/RayhanADev/crosis4furrets",
	"devDependencies": {
		"@babel/core": "^7.15.8",
		"@babel/preset-env": "^7.16.0",
		"@rollup/plugin-babel": "^5.3.0",
		"@rollup/plugin-commonjs": "^21.0.1",
		"@rollup/plugin-node-resolve": "^13.0.6",
		"eslint": "^7.28.0",
		"prettier": "^2.3.1",
		"rimraf": "^3.0.2",
		"rollup": "^2.51.2",
		"rollup-plugin-terser": "^7.0.2"
	},
	"dependencies": {
		"@replit/crosis": "^7.2.0",
		"@replit/protocol": "^0.2.42",
		"gitignore-parser": "^0.0.2",
		"graphql": "^15.6.1",
		"graphql-request": "^3.6.1",
		"lightfetch-node": "^1.1.1"
	}
}
